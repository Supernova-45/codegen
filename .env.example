CLARIFYCODE_API_KEY=replace_me
CLARIFYCODE_BASE_URL=https://api.openai.com/v1
CLARIFYCODE_MODEL=meta-llama/llama-3.1-8b-instruct
# Optional dedicated model for clarification-test generation.
# If unset, test generation uses the same model as code generation.
# CLARIFYCODE_TESTGEN_API_KEY=replace_me
# CLARIFYCODE_TESTGEN_BASE_URL=https://api.groq.com/openai/v1
# CLARIFYCODE_TESTGEN_MODEL=llama-3.1-70b-versatile
# CLARIFYCODE_TESTGEN_TEMPERATURE=0.2
# CLARIFYCODE_TESTGEN_REQUEST_TIMEOUT_S=90
# Optional per-process spacing between API calls (seconds).
# Useful to reduce 429s when running many shards concurrently.
# Example: CLARIFYCODE_MIN_REQUEST_INTERVAL_S=0.35
# CLARIFYCODE_MIN_REQUEST_INTERVAL_S=0

# Optional key-pool loading from .env for sharding/rotation:
# 1) Reference env var names that contain keys:
# CLARIFYCODE_API_KEY_ENV_POOL=GROK_KEY_1,GROK_KEY_2,GROK_KEY_3,GROK_KEY_4,GROK_KEY_5,GROK_KEY_6
# GROK_KEY_1=replace_me
# GROK_KEY_2=replace_me
# ...
#
# 2) Or provide keys directly in one variable:
# CLARIFYCODE_API_KEY_POOL=key1,key2,key3,key4,key5,key6

# Optional profile variables for scripts/run_model_matrix.py:
# MODAL_BASE_URL=https://...
# MODAL_API_KEY=replace_me
# MODAL_QWEN_CHEAP_MODEL=qwen/qwen2.5-coder-7b-instruct
# MODAL_OPENAI_BASE_URL=https://<your-endpoint>.modal.run
# MODAL_OPENAI_API_KEY=dummy
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_API_KEY=replace_me
# GROQ_LLAMA_TEST_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=replace_me
# OPENAI_MID_MODEL=gpt-4.1-mini
# OPENAI_LARGE_MODEL=gpt-5
# GOOGLE_OPENAI_BASE_URL=https://.../openapi
# GOOGLE_OPENAI_API_KEY=replace_me
# GOOGLE_LARGE_MODEL=gemini-2.5-pro
