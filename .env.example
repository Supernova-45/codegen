CLARIFYCODE_API_KEY=replace_me
CLARIFYCODE_BASE_URL=https://api.openai.com/v1
CLARIFYCODE_MODEL=meta-llama/llama-3.1-8b-instruct

# Optional key-pool loading from .env for sharding/rotation:
# 1) Reference env var names that contain keys:
# CLARIFYCODE_API_KEY_ENV_POOL=GROK_KEY_1,GROK_KEY_2,GROK_KEY_3,GROK_KEY_4,GROK_KEY_5,GROK_KEY_6
# GROK_KEY_1=replace_me
# GROK_KEY_2=replace_me
# ...
#
# 2) Or provide keys directly in one variable:
# CLARIFYCODE_API_KEY_POOL=key1,key2,key3,key4,key5,key6
